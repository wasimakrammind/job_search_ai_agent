OPENROUTER_API_KEY="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"

# Which model to use for tailoring resumes/cover letters
# Budget-friendly options (cost per 1M tokens):
#   google/gemini-2.0-flash-001        — $0.10 input / $0.40 output  (BEST VALUE)
#   deepseek/deepseek-chat-v3-0324:free — FREE
#   meta-llama/llama-4-maverick:free    — FREE
#   mistralai/mistral-small-3.1-24b-instruct:free — FREE
#   qwen/qwen3-235b-a22b:free          — FREE
#   openai/gpt-4o-mini                 — $0.15 / $0.60
#   anthropic/claude-sonnet-4           — $3.00 / $15.00  (premium, use sparingly)
